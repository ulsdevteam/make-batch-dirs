        logger.info(f"Copying spreadsheet to {batch_path}/manifest.xlsx")
        print(f"Copying spreadsheet to {batch_path}/manifest.xlsx")
        shutil.copyfile(args.xls_file, batch_path+"/manifest.xlsx")
